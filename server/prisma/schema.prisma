// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id              String    @id @default(cuid())
  name            String
  address         String
  affiliationNo   String?
  logoUrl         String?
  phone           String
  academic        AcademicSession[]
  students        Student[]
  staff           Staff[]
  users           User[]
}

model AcademicSession {
  id        String   @id @default(cuid())
  name      String   // "2025-26"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
}

model Student {
  id            String   @id @default(cuid())
  admissionNo   String   @unique
  name          String
  fatherName    String
  motherName    String
  className     String
  section       String
  dob           DateTime
  gender        String
  aadhaar       String?
  category      String   // General, OBC, SC, ST
  isRTE         Boolean  @default(false)
  phone         String
  address       String
  photoUrl      String?
  status        String   @default("Active") // Active, TC Issued, Dropped
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])
  attendance    Attendance[]
  fees          Fee[]
  marks         ExamMark[]
  createdAt     DateTime @default(now())
}

model Attendance {
  id        String   @id @default(cuid())
  date      DateTime
  status    String   // Present, Absent, Late, Holiday
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  markedBy  String   // Teacher userId
  @@unique([studentId, date])
}

model FeeStructure {
  id        String  @id @default(cuid())
  className String
  feeType   String  // Tuition, Transport, Lab, Annual
  amount    Float
  cycle     String  // Monthly, Quarterly, Annual
  schoolId  String
}

model Fee {
  id          String   @id @default(cuid())
  amount      Float
  paidAmount  Float    @default(0)
  lateFee     Float    @default(0)
  status      String   // Paid, Partial, Pending, Overdue
  dueDate     DateTime
  paidDate    DateTime?
  feeType     String
  receiptNo   String?
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  createdAt   DateTime @default(now())
}

model Exam {
  id        String     @id @default(cuid())
  name      String     // "Unit Test 1", "Half Yearly"
  date      DateTime
  className String
  marks     ExamMark[]
}

model ExamMark {
  id         String  @id @default(cuid())
  subject    String
  maxMarks   Float
  obtained   Float
  grade      String?
  studentId  String
  student    Student @relation(fields: [studentId], references: [id])
  examId     String
  exam       Exam    @relation(fields: [examId], references: [id])
}

model Staff {
  id            String   @id @default(cuid())
  staffId       String   @unique
  name          String
  designation   String   // Principal, Teacher, Clerk, Peon, Driver
  type          String   // Teaching, Non-Teaching
  qualification String
  aadhaar       String?
  phone         String
  photoUrl      String?
  basicSalary   Float
  da            Float    @default(0)  // Dearness Allowance
  hra           Float    @default(0)  // House Rent Allowance
  allowances    Float    @default(0)
  pfDeduction   Float    @default(0)
  tdsDeduction  Float    @default(0)
  joiningDate   DateTime
  subjects      String?  // Comma-separated: "Maths, Science"
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])
  leaves        Leave[]
  salarySlips   SalarySlip[]
  attendance    StaffAttendance[]
  timetableSlots TimetableSlot[]
}

model StaffAttendance {
  id        String   @id @default(cuid())
  date      DateTime
  checkIn   DateTime?
  checkOut  DateTime?
  status    String   // Present, Absent, Half-Day, On-Leave
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id])
  @@unique([staffId, date])
}

model Leave {
  id        String   @id @default(cuid())
  type      String   // CL, EL, Medical, Maternity, Duty
  fromDate  DateTime
  toDate    DateTime
  days      Int
  reason    String?
  status    String   // Pending, Approved, Rejected
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id])
}

model SalarySlip {
  id            String   @id @default(cuid())
  month         String   // "March 2026"
  grossSalary   Float
  totalDeductions Float
  netSalary     Float
  absentDays    Int      @default(0)
  absentDeduction Float  @default(0)
  status        String   // Generated, Paid, Delayed
  paidDate      DateTime?
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id])
  createdAt     DateTime @default(now())
}

model TimetableSlot {
  id        String @id @default(cuid())
  day       String // Monday, Tuesday...
  period    Int    // 1, 2, 3...
  startTime String // "09:00"
  endTime   String // "09:45"
  subject   String
  className String
  section   String
  room      String?
  staffId   String
  staff     Staff  @relation(fields: [staffId], references: [id])
}

model Vehicle {
  id            String  @id @default(cuid())
  vehicleNo     String  @unique
  type          String  // Bus, Van
  capacity      Int
  driverName    String
  driverPhone   String
  routeName     String
  stops         String  // JSON array of stop names
  schoolId      String
}

model Book {
  id          String @id @default(cuid())
  accessionNo String @unique
  title       String
  author      String
  isbn        String?
  category    String
  quantity    Int    @default(1)
  available   Int    @default(1)
  shelfLocation String?
  schoolId    String
  issues      BookIssue[]
}

model BookIssue {
  id         String    @id @default(cuid())
  issueDate  DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?
  fine       Float     @default(0)
  status     String    // Issued, Returned, Overdue
  bookId     String
  book       Book      @relation(fields: [bookId], references: [id])
  studentId  String
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
  role     String // ADMIN, PRINCIPAL, TEACHER, ACCOUNTANT, LIBRARIAN, TRANSPORT
  name     String
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])
}
