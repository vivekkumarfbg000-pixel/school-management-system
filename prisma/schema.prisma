// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model School {
  id              String    @id @default(cuid())
  name            String
  address         String
  affiliationNo   String?
  logoUrl         String?
  phone           String
  academic        AcademicSession[]
  students        Student[]
  staff           Staff[]
  users           User[]
}

model AcademicSession {
  id        String   @id @default(cuid())
  name      String   // "2025-26"
  start_date DateTime
  end_date   DateTime
  isActive  Boolean  @default(true)
  school_id  String
  school    School   @relation(fields: [school_id], references: [id])
}

model Student {
  id            String   @id @default(cuid())
  admission_no   String   @unique
  name          String
  father_name    String
  mother_name    String
  class_name     String
  section       String
  dob           DateTime
  gender        String
  aadhaar       String?
  category      String   // General, OBC, SC, ST
  is_rte         Boolean  @default(false)
  phone         String
  address       String
  photo_url      String?
  status        String   @default("Active") // Active, TC Issued, Dropped
  school_id      String
  school        School   @relation(fields: [school_id], references: [id])
  attendance    Attendance[]
  fees          Fee[]
  marks         ExamMark[]
  createdAt     DateTime @default(now())
}

model Attendance {
  id        String   @id @default(cuid())
  date      DateTime
  status    String   // Present, Absent, Late, Holiday
  student_id String
  student   Student  @relation(fields: [student_id], references: [id])
  marked_by  String   // Teacher userId
  @@unique([student_id, date])
}

model FeeStructure {
  id        String  @id @default(cuid())
  class_name String
  fee_type   String  // Tuition, Transport, Lab, Annual
  amount    Float
  cycle     String  // Monthly, Quarterly, Annual
  school_id  String
}

model Fee {
  id          String   @id @default(cuid())
  amount      Float
  paid_amount  Float    @default(0)
  late_fee     Float    @default(0)
  status      String   // Paid, Partial, Pending, Overdue
  due_date     DateTime
  paid_date    DateTime?
  fee_type     String
  receipt_no   String?
  student_id   String
  student     Student  @relation(fields: [student_id], references: [id])
  createdAt   DateTime @default(now())
}

model Exam {
  id        String     @id @default(cuid())
  name      String     // "Unit Test 1", "Half Yearly"
  date      DateTime
  class_name String
  marks     ExamMark[]
}

model ExamMark {
  id         String  @id @default(cuid())
  subject    String
  max_marks   Float
  obtained   Float
  grade      String?
  student_id  String
  student    Student @relation(fields: [student_id], references: [id])
  exam_id     String
  exam       Exam    @relation(fields: [exam_id], references: [id])
}

model Staff {
  id            String   @id @default(cuid())
  staff_id       String   @unique
  name          String
  designation   String   // Principal, Teacher, Clerk, Peon, Driver
  type          String   // Teaching, Non-Teaching
  qualification String
  aadhaar       String?
  phone         String
  photo_url      String?
  basic_salary   Float
  da            Float    @default(0)  // Dearness Allowance
  hra           Float    @default(0)  // House Rent Allowance
  allowances    Float    @default(0)
  pfDeduction   Float    @default(0)
  tdsDeduction  Float    @default(0)
  joining_date   DateTime
  subjects      String?  // Comma-separated: "Maths, Science"
  school_id      String
  school        School   @relation(fields: [school_id], references: [id])
  leaves        Leave[]
  salarySlips   SalarySlip[]
  attendance    StaffAttendance[]
  timetableSlots TimetableSlot[]
}

model StaffAttendance {
  id        String   @id @default(cuid())
  date      DateTime
  check_in   DateTime?
  check_out  DateTime?
  status    String   // Present, Absent, Half-Day, On-Leave
  staff_id   String
  staff     Staff    @relation(fields: [staff_id], references: [id])
  @@unique([staff_id, date])
}

model Leave {
  id        String   @id @default(cuid())
  type      String   // CL, EL, Medical, Maternity, Duty
  from_date  DateTime
  to_date    DateTime
  days      Int
  reason    String?
  status    String   // Pending, Approved, Rejected
  staff_id   String
  staff     Staff    @relation(fields: [staff_id], references: [id])
}

model SalarySlip {
  id            String   @id @default(cuid())
  month         String   // "March 2026"
  gross_salary   Float
  total_deductions Float
  net_salary     Float
  absent_days    Int      @default(0)
  absent_deduction Float  @default(0)
  status        String   // Generated, Paid, Delayed
  paid_date      DateTime?
  staff_id       String
  staff         Staff    @relation(fields: [staff_id], references: [id])
  createdAt     DateTime @default(now())
}

model TimetableSlot {
  id        String @id @default(cuid())
  day       String // Monday, Tuesday...
  period    Int    // 1, 2, 3...
  start_time String // "09:00"
  end_time   String // "09:45"
  subject   String
  class_name String
  section   String
  room      String?
  staff_id   String
  staff     Staff  @relation(fields: [staff_id], references: [id])
}

model Vehicle {
  id            String  @id @default(cuid())
  vehicle_no     String  @unique
  type          String  // Bus, Van
  capacity      Int
  driver_name    String
  driver_phone   String
  route_name     String
  stops         String  // JSON array of stop names
  school_id      String
}

model Book {
  id          String @id @default(cuid())
  accession_no String @unique
  title       String
  author      String
  isbn        String?
  category    String
  quantity    Int    @default(1)
  available   Int    @default(1)
  shelf_location String?
  school_id    String
  issues      BookIssue[]
}

model BookIssue {
  id         String    @id @default(cuid())
  issue_date  DateTime  @default(now())
  due_date    DateTime
  return_date DateTime?
  fine       Float     @default(0)
  status     String    // Issued, Returned, Overdue
  book_id     String
  book       Book      @relation(fields: [book_id], references: [id])
  student_id  String
}

model User {
  id        String @id @default(cuid())
  username  String? @unique
  email     String @unique
  password  String
  role      String // ADMIN, PRINCIPAL, TEACHER, ACCOUNTANT, LIBRARIAN, TRANSPORT
  name      String
  school_id String
  school    School @relation(fields: [school_id], references: [id])
}
