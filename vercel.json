{
  "version": 2,
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/server-api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api|server-api).*)",
      "destination": "/dist/$1"
    }
  ]
}
