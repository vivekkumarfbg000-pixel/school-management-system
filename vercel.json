{
  "version": 2,
  "rewrites": [
    {
      "source": "/server-api/login",
      "destination": "/server-api/login.js"
    },
    {
      "source": "/server-api/signup",
      "destination": "/server-api/signup.js"
    },
    {
      "source": "/server-api/(.*)",
      "destination": "/server-api/all.js"
    },
    {
      "source": "/(.*)",
      "destination": "/client/$1"
    }
  ]
}
