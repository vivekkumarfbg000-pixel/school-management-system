{
  "version": 2,
  "rewrites": [

    {
      "source": "/(index.html)?",
      "destination": "/dist/index.html"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/dist/assets/$1"
    },
    {
      "source": "/((?!api|assets|favicon.ico).*)",
      "destination": "/dist/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/index.html"
    }
  ]
}
