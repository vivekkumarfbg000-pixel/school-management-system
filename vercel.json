{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/test-health",
      "destination": "/api/test-health.js"
    },
    {
      "source": "/api/cron/reminders",
      "destination": "/api/cron/reminders.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "30 2 * * *"
    }
  ]
}
