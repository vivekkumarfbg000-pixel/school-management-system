{
  "name": "edustream-saas",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "install-all": "npm install && cd client && npm install",
    "dev": "concurrently \"cd client && npm run dev\" \"npx nodemon server/server.js\"",
