    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^1.1.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.473.0",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "razorpay": "^2.9.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
